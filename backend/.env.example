NODE_ENV=development
PORT=3000

# Conexão usada pela aplicação (API e workers) — role restrita, sem BYPASSRLS
DATABASE_URL=postgresql://fidelizza_app:fidelizza_app@localhost:5432/fidelizza
# Conexão usada apenas pelo runner de migrations — superuser
DATABASE_MIGRATION_URL=postgresql://fidelizza:fidelizza@localhost:5432/fidelizza
# Senha da role de aplicação (sincronizar com POSTGRES_APP_PASSWORD no docker-compose)
POSTGRES_APP_PASSWORD=fidelizza_app

REDIS_HOST=localhost
REDIS_PORT=6379

# Mínimo 32 caracteres cada — gere com: openssl rand -hex 32
JWT_SECRET=substitua-por-um-segredo-com-pelo-menos-32-chars
JWT_REFRESH_SECRET=substitua-por-outro-segredo-com-pelo-menos-32

# Chave AES-256 para encriptar credenciais de integração no banco (ADR-021)
# Gere com: openssl rand -hex 32
AES_SECRET=substitua-por-chave-aes-com-pelo-menos-32-chars
